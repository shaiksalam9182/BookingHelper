<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F0F3F4"
    android:padding="4dp">

    <!-- Header bar with switch button -->
    <LinearLayout
        android:id="@+id/keyboard_header"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:id="@+id/btn_switch_keyboard"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:contentDescription="Switch Keyboard"
            android:padding="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="QUICK-FILL PANEL"
            android:textSize="12sp"
            android:textColor="#5D6D7E"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.1" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" /> <!-- Spacer -->
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:overScrollMode="never">
        
        <GridLayout
            android:id="@+id/keyboard_grid_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:padding="4dp"
            android:alignmentMode="alignMargins"
            android:rowOrderPreserved="false" />
    </ScrollView>

</LinearLayout>
