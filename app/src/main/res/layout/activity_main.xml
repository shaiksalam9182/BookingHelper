<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F3F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile Manager"
            android:textSize="24sp"
            android:textColor="#1A237E"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure your one-tap filling profiles."
            android:textSize="14sp"
            android:textColor="#546E7A"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Number of Active Pilgrims"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_marginBottom="20dp"
            app:boxStrokeColor="#3498DB"
            app:hintTextColor="#2980B9">
            <AutoCompleteTextView
                android:id="@+id/act_person_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="#2C3E50"
                android:backgroundTint="#FFFFFF"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Person Sections Container -->
        <LinearLayout
            android:id="@+id/container_persons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Person Template (IDs: 1 to 4) -->
            <include layout="@layout/item_person_card" android:id="@+id/person_card_1" />
            <include layout="@layout/item_person_card" android:id="@+id/person_card_2" />
            <include layout="@layout/item_person_card" android:id="@+id/person_card_3" />
            <include layout="@layout/item_person_card" android:id="@+id/person_card_4" />
        </LinearLayout>

        <!-- General Details Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="COMMON ADDRESS" android:textStyle="bold" android:textColor="#7F8C8D" android:layout_marginBottom="12dp" android:textSize="12sp"/>
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:hint="Email" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_height="wrap_content" android:layout_marginBottom="8dp" app:boxBackgroundColor="#FFFFFF"><com.google.android.material.textfield.TextInputEditText android:id="@+id/et_email" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#2C3E50"/></com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:hint="City" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_height="wrap_content" android:layout_marginBottom="8dp" app:boxBackgroundColor="#FFFFFF"><com.google.android.material.textfield.TextInputEditText android:id="@+id/et_city" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#2C3E50"/></com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:hint="State" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_height="wrap_content" android:layout_marginBottom="8dp" app:boxBackgroundColor="#FFFFFF"><com.google.android.material.textfield.TextInputEditText android:id="@+id/et_state" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#2C3E50"/></com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:hint="Country" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_height="wrap_content" android:layout_marginBottom="8dp" app:boxBackgroundColor="#FFFFFF"><com.google.android.material.textfield.TextInputEditText android:id="@+id/et_country" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#2C3E50"/></com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:hint="Pincode" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_height="wrap_content" app:boxBackgroundColor="#FFFFFF"><com.google.android.material.textfield.TextInputEditText android:id="@+id/et_pincode" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#2C3E50" android:inputType="number"/></com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SAVE ALL DETAILS"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:backgroundTint="#3F51B5"
            android:layout_marginTop="16dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_enable_keyboard"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SETUP KEYBOARD"
                android:textColor="#3F51B5" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_wipe"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="WIPE ALL DATA"
                android:textColor="#E74C3C" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
